# --- Application ---
APP_NAME=fastapi-clean-backend
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000

# --- Database (Track A: asyncpg + Postgres behind repository ports) ---
# DB_PROVIDER selects the adapter wired in the composition root; app code never sees it.
DB_PROVIDER=sqlite
POSTGRES_DATABASE_URL=
SQLITE_DATABASE_URL=./local.db
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT=30

# --- Redis ---
REDIS_URL=

# --- Auth: Supabase GoTrue (BFF — server-to-server only) ---
SUPABASE_PROJECT_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
OAUTH_PROVIDER=google
OAUTH_REDIRECT_URI=
FRONTEND_POST_LOGIN_URL=http://localhost:3000/
# JWKS_CACHE_TTL_SECONDS=3600

# --- Session cookies (opaque id only; tokens never reach the browser) ---
# SESSION_COOKIE_NAME=sid
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_DOMAIN=
# SESSION_ABSOLUTE_TTL_SECONDS=43200
# SESSION_IDLE_TTL_SECONDS=1800

# --- CSRF double-submit ---
# CSRF_COOKIE_NAME=csrftoken
# CSRF_HEADER_NAME=X-CSRF-Token

# --- PKCE login flow ---
# PKCE_STATE_COOKIE_NAME=auth_state
# PKCE_STATE_TTL_SECONDS=600

# --- Authorization ---
CASBIN_MODEL_PATH=app/authorization/casbin_model.conf

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=INFO

# --- Startup flags: nothing connects unless explicitly enabled ---
STARTUP_CONNECT_DATABASE=false
STARTUP_CONNECT_REDIS=false
STARTUP_LOAD_CASBIN=false
STARTUP_CREATE_CELERY=false
STARTUP_PRELOAD_JWKS=false
