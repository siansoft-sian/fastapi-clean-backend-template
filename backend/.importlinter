[importlinter]
root_package = app
include_external_packages = True

[importlinter:contract:domain-and-usecases-pure]
name = Domain and use cases stay framework-free
type = forbidden
source_modules =
    app.modules.*.domain
    app.modules.*.application
forbidden_modules =
    fastapi
    starlette
    asyncpg
    redis
    celery
    casbin
    httpx

[importlinter:contract:api-no-db-adapters]
name = API layer does not import DB adapters directly
type = forbidden
source_modules =
    app.modules.*.api
forbidden_modules =
    app.db
; Direct-only: module routers may use auth/boundary Depends whose internals
; (session repository) legitimately reach app.db — routers themselves must not.
allow_indirect_imports = True

[importlinter:contract:auth-core-framework-free]
name = Auth core logic stays FastAPI-free (only cookies/dependencies/routes may touch it)
type = forbidden
source_modules =
    app.auth.auth_context
    app.auth.csrf
    app.auth.exceptions
    app.auth.identity_mapper
    app.auth.jwks_client
    app.auth.jwt_verifier
    app.auth.pkce
    app.auth.scopes
    app.auth.session_repository
    app.auth.session_tokens
    app.auth.supabase_auth_client
    app.auth.token_cipher
forbidden_modules =
    fastapi
    starlette

[importlinter:contract:rate-limiting-core-framework-free]
name = Rate-limiting core stays FastAPI-free (only dependency.py and the middleware touch it)
type = forbidden
source_modules =
    app.rate_limiting.backend
    app.rate_limiting.client_ip
    app.rate_limiting.keys
    app.rate_limiting.limiter
    app.rate_limiting.rules
forbidden_modules =
    fastapi
    starlette

[importlinter:contract:authorization-framework-free]
name = Authorization layer stays FastAPI-free (only the require_scope dependency touches FastAPI)
type = forbidden
source_modules =
    app.authorization
forbidden_modules =
    fastapi
    starlette

[importlinter:contract:only-db-knows-asyncpg]
name = Only app.db and module infrastructure may import asyncpg directly
type = forbidden
source_modules =
    app.api
    app.core
    app.bootstrap
    app.shared
forbidden_modules =
    asyncpg
allow_indirect_imports = True
